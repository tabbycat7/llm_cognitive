# ── Paradox Stress Test Configuration ──
# Copy this file to .env and fill in your API keys.

# ── Default / Fallback (OpenAI-compatible) ──
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Judge Model (used for scoring paradox responses) ──
JUDGE_API_KEY=sk-xxx
JUDGE_BASE_URL=https://api.openai.com/v1
JUDGE_MODEL=gpt-4o

# ── Per-model overrides (optional) ──
# Format: <SAFE_MODEL_ID>_API_KEY / _BASE_URL / _MODEL
# where SAFE_MODEL_ID = model_id with - and . replaced by _,  UPPERCASED
#
# Example for deepseek:
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
#
# Example for anthropic-claude-haiku-4.5 → ANTHROPIC_CLAUDE_HAIKU_4_5:
# ANTHROPIC_CLAUDE_HAIKU_4_5_API_KEY=sk-xxx
# ANTHROPIC_CLAUDE_HAIKU_4_5_BASE_URL=https://xxx
# ANTHROPIC_CLAUDE_HAIKU_4_5_MODEL=claude-haiku-4-5
#
# Example for openai-gpt-5.4-mini → OPENAI_GPT_5_4_MINI:
# OPENAI_GPT_5_4_MINI_API_KEY=sk-xxx
# OPENAI_GPT_5_4_MINI_BASE_URL=https://api.openai.com/v1
# OPENAI_GPT_5_4_MINI_MODEL=gpt-5.4-mini
#
# Example for google-gemini-2.5-flash → GOOGLE_GEMINI_2_5_FLASH:
# GOOGLE_GEMINI_2_5_FLASH_API_KEY=xxx
# GOOGLE_GEMINI_2_5_FLASH_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GOOGLE_GEMINI_2_5_FLASH_MODEL=gemini-2.5-flash
#
# Example for doubao-seed-2-0-lite-260215 → DOUBAO_SEED_2_0_LITE_260215:
# DOUBAO_SEED_2_0_LITE_260215_API_KEY=xxx
# DOUBAO_SEED_2_0_LITE_260215_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_SEED_2_0_LITE_260215_MODEL=doubao-seed-2-0-lite-260215
#
# Example for kimi-k2.6 → KIMI_K2_6:
# KIMI_K2_6_API_KEY=xxx
# KIMI_K2_6_BASE_URL=https://api.moonshot.cn/v1
# KIMI_K2_6_MODEL=kimi-k2.6
#
# Example for MiniMax-M2.5 → MINIMAX_M2_5:
# MINIMAX_M2_5_API_KEY=xxx
# MINIMAX_M2_5_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_M2_5_MODEL=MiniMax-M2.5
